# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nadlanka?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# Session Secret
SESSION_SECRET=your-session-secret-key-here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Client URL (for OAuth redirects and email verification links redirect)
CLIENT_URL=http://localhost:3000

# Email - REQUIRED for verification emails to be delivered (otherwise users never receive the link)
# Gmail: use your Gmail address and an App Password (https://myaccount.google.com/apppasswords)
# Other: set EMAIL_HOST, EMAIL_PORT (e.g. 587), and optionally EMAIL_SECURE=true for 465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-or-smtp-password
# Optional: EMAIL_FROM=noreply@yourdomain.com  EMAIL_HOST=smtp.example.com  EMAIL_PORT=587

# Server Port
PORT=5000

# Server URL (for OAuth and image URLs)
SERVER_URL=https://your-app.onrender.com

# Cloudinary Configuration (for image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret